<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.learning.mapper.StockMapper">

    <select id="selectAll" resultType="map">
        select * from ent_sys_user
    </select>
    <select id="selectOne" resultType="com.clearning.entity.po.StockPO">
        select * from ent_stock s
        <where>
            <if test="name !=null and name !=''">
                s.name = #{name}
            </if>
            <if test="id !=null and id !=''">
                s.id = #{id}
            </if>
        </where>
    </select>
    <select id="insert">
        INSERT INTO ent_stock(id, name,count)
        VALUES (#{id}, #{name},#{count});
    </select>

    <select id="reduce">
        update ent_stock s
        set s.count = s.count - 1
        where s.id = #{id}
    </select>
</mapper>