input PageFilter{
    pageIndex:Int
    pageSize:Int
}
type PageResult{
    pageIndex:Int
    pageSize:Int
    total:Int
}
input BookFilter{
    page:PageFilter
    name:String
}

type BookPageResult{
    page:PageResult
    list:[Book]
}

type Query {
    books(filter:BookFilter):BookPageResult
    bookById(id: ID): Book
}

type Book {
    id: ID
    name: String
    pageCount: Int
    author: Author
}

type Author {
    id: ID
    firstName: String
    lastName: String
}